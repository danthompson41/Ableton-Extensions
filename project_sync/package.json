{
  "name": "project-sync",
  "version": "1.0.0",
  "description": "Project Sync — read-only inspector for everything the Live Extensions SDK exposes about the current Set",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "dist/extension.js",
  "scripts": {
    "build": "tsc --noEmit && tsx build.ts --production",
    "build:dev": "tsc --noEmit && tsx build.ts",
    "start": "npm run build:dev && extensions-cli run",
    "package": "npm run build && extensions-cli package"
  },
  "devDependencies": {
    "@ableton-extensions/cli": "file:../ableton-extensions-cli-1.0.0-beta.0.tgz",
    "@types/node": "^25.2.3",
    "esbuild": "0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@ableton-extensions/sdk": "file:../ableton-extensions-sdk-1.0.0-beta.0.tgz"
  }
}
